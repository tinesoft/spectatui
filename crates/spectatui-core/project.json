{
  "name": "spectatui-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "./crates/spectatui-core/src",
  "targets": {
    "build": {
      "executor": "@monodon/rust:check",
      "outputs": ["{options.target-dir}"],
      "options": {
        "target-dir": "dist/target/spectatui-core"
      }
    },
    "test": {
      "cache": true,
      "executor": "@monodon/rust:test",
      "options": {
        "target-dir": "dist/target/spectatui-core"
      },
      "configurations": {
        "production": { "release": true }
      }
    },
    "lint": {
      "cache": true,
      "executor": "@monodon/rust:lint",
      "options": {
        "target-dir": "dist/target/spectatui-core",
        "args": ["-D", "warnings"]
      }
    },
    "check": {
      "cache": true,
      "executor": "@monodon/rust:check",
      "options": {
        "target-dir": "dist/target/spectatui-core"
      }
    },
    "fmt": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p spectatui-core -- --check"
      }
    }
  },
  "tags": []
}
